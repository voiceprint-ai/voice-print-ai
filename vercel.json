{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "framework": "express",
      "rewrites": [
        {
          "source": "/api/backend/:path*",
          "destination": "/:path*"
        }
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/backend/:path*",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/:path*",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}