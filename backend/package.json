{
  "name": "voice-print-ai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for Voiceprint AI — voice profile generation, consistency scoring, and voice-matched rewriting.",
  "author": "Saamarth Attray",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test:token": "tsx scripts/get-test-token.ts",
    "secrets:scan": "grep -rInE '(sk-ant-|AKIA|-----BEGIN|api[_-]?key\\s*=\\s*[\"'\\''][A-Za-z0-9]{16,})' src || echo 'No obvious secrets found in src/'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "express-rate-limit": "7.5.1",
    "firebase-admin": "12.7.0",
    "helmet": "8.0.0",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.16.11",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
