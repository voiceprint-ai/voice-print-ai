# =============================================================================
# Voiceprint AI backend — example environment file.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# The app FAILS FAST on boot if required vars are missing or left at defaults.
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=8080
# Comma-separated exact origins allowed to call this API (no wildcards).
CORS_ORIGINS=http://localhost:3000

# --- Firebase (Admin SDK) ---
# Path to your Firebase service-account JSON. Keep it OUT of git (see .gitignore).
# In production (Cloud Run) prefer Application Default Credentials and leave this blank.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
FIREBASE_PROJECT_ID=voiceprint-ai
# Only needed for scripts/get-test-token.ts (local testing without a frontend).
# Firebase Console > Project settings > General > Web API Key. Not a server secret —
# it's the same key embedded in every Firebase web app's public client config.
FIREBASE_WEB_API_KEY=

# --- LLM provider ---
# One of: anthropic | watsonx | mock
# Use `mock` for local dev / teammates without a key (no network, no spend).
LLM_PROVIDER=mock
# Required only when LLM_PROVIDER=anthropic. Server-side only — never shipped to the client.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- IBM watsonx.ai (Granite) ---
# Required only when LLM_PROVIDER=watsonx.
# API key: IBM Cloud console > Manage > Access (IAM) > API keys.
WATSONX_API_KEY=
# Project ID: watsonx.ai project > Manage tab > General.
WATSONX_PROJECT_ID=
# Region base URL — match the region your watsonx project was created in.
# e.g. us-south -> https://us-south.ml.cloud.ibm.com, eu-de -> https://eu-de.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com
   # NOTE: model availability is per-project/per-region, not global — a model
   # that exists in IBM's docs can still 404 with "model_not_supported" if it's
   # not in YOUR project's catalog. Before assuming this default works, check
   # watsonx.ai > your project > Prompt Lab > model picker > "All models" to see
   # what's actually available to you, and swap this value if needed.
   # Confirmed working in the "voiceprint" project (Dallas/us-south) as of July 2026:
   WATSONX_MODEL_ID=ibm/granite-4-h-small

# --- Abuse / spend guards ---
# Max LLM-backed operations (profile/analyze/rewrite) per user per rolling day.
DAILY_LLM_QUOTA_PER_USER=100
# Hard input caps (characters). Reject anything larger before it reaches the model.
MAX_SAMPLE_CHARS=50000
MAX_TARGET_CHARS=50000
MAX_SAMPLES_PER_PROFILE=50