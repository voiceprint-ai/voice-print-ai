# =============================================================================
# Voiceprint AI backend — example environment file.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# The app FAILS FAST on boot if required vars are missing or left at defaults.
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=8080
# Comma-separated exact origins allowed to call this API (no wildcards).
CORS_ORIGINS=http://localhost:3000

# --- Firebase (Admin SDK) ---
# Path to your Firebase service-account JSON. Keep it OUT of git (see .gitignore).
# In production (Cloud Run) prefer Application Default Credentials and leave this blank.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
FIREBASE_PROJECT_ID=voiceprint-ai
FIREBASE_WEB_API_KEY=

# --- LLM provider ---
# One of: anthropic | mock
# Use `mock` for local dev / teammates without a key (no network, no spend).
LLM_PROVIDER=mock
# Required only when LLM_PROVIDER=anthropic. Server-side only — never shipped to the client.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Abuse / spend guards ---
# Max LLM-backed operations (profile/analyze/rewrite) per user per rolling day.
DAILY_LLM_QUOTA_PER_USER=100
# Hard input caps (characters). Reject anything larger before it reaches the model.
MAX_SAMPLE_CHARS=50000
MAX_TARGET_CHARS=50000
MAX_SAMPLES_PER_PROFILE=50